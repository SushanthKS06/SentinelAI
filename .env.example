# SentinelAI Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Application Configuration
# =============================================================================
APP_NAME=SentinelAI
APP_ENV=development
APP_VERSION=0.1.0
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# =============================================================================
# Database Configuration
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sentinelai
POSTGRES_USER=sentinelai
POSTGRES_PASSWORD=changeme
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=10
POSTGRES_POOL_TIMEOUT=30
POSTGRES_ECHO=false

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=50
REDIS_SSL=false

# =============================================================================
# Kafka Configuration
# =============================================================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CLIENT_ID=sentinelai
KAFKA_CONSUMER_GROUP=sentinelai-consumers
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_AUTO_OFFSET_RESET=latest
KAFKA_ENABLE_AUTO_COMMIT=true
KAFKA_MAX_POLL_RECORDS=500

# =============================================================================
# ClickHouse Configuration
# =============================================================================
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_DATABASE=sentinelai
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_COMPRESSION=lz4

# =============================================================================
# Qdrant (Vector Database) Configuration
# =============================================================================
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=sentinelai_vectors
QDRANT_DISTANCE=cosine

# =============================================================================
# vLLM Configuration
# =============================================================================
VLLM_HOST=localhost
VLLM_PORT=8000
VLLM_API_KEY=EMPTY
VLLM_MODEL=llama-3-8b-instruct
VLLM_MAX_TOKENS=4096
VLLM_TEMPERATURE=0.7
VLLM_TOP_P=0.9
VLLM_TOP_K=50

# =============================================================================
# Security Configuration
# =============================================================================
SECRET_KEY=changeme-insecure-secret-key-replace-in-production
JWT_SECRET_KEY=changeme-jwt-secret-key-replace-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_RESET_PASSWORD_EXPIRE_MINUTES=15
JWT_VERIFICATION_EXPIRE_HOURS=24

# =============================================================================
# CORS Configuration
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# =============================================================================
# Rate Limiting Configuration
# =============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_OUTPUT=stdout
LOG_INCLUDE_TIMESTAMP=true
LOG_INCLUDE_CORRELATION_ID=true
LOG_INCLUDE_REQUEST_ID=true

# =============================================================================
# OpenTelemetry Configuration
# =============================================================================
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_SERVICE_NAME=sentinelai
OTEL_RESOURCE_ATTRIBUTES=service.name=sentinelai,service.version=0.1.0

# =============================================================================
# Prometheus Configuration
# =============================================================================
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
PROMETHEUS_NAMESPACE=sentinelai

# =============================================================================
# Celery Configuration
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TIMEZONE=UTC
CELERY_ENABLE_UTC=true
CELERY_TASK_TRACK_STARTED=true
CELERY_TASK_TIME_LIMIT=3600
CELERY_WORKER_PREFETCH_MULTIPLIER=4

# =============================================================================
# Temporal Configuration
# =============================================================================
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=sentinelai
TEMPORAL_TASK_QUEUE=sentinelai-task-queue
TEMPORAL_CONNECT_TIMEOUT=10
TEMPORAL_EXECUTION_TIMEOUT=300

# =============================================================================
# AI Configuration
# =============================================================================
AI_PROVIDER=vllm
AI_MODEL=llama-3-8b-instruct
AI_MAX_RETRIES=3
AI_RETRY_DELAY=1
AI_TIMEOUT=30
AI_TEMPERATURE=0.7
AI_TOP_P=0.9
AI_TOP_K=50
AI_MAX_TOKENS=4096

# Embedding Configuration
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=32

# RAG Configuration
RAG_TOP_K=10
RAG_RERANK_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7
RAG_MAX_CONTEXT_TOKENS=8000

# =============================================================================
# ML Configuration
# =============================================================================
ML_ANOMALY_DETECTION_ENABLED=true
ML_ANOMALY_THRESHOLD=0.95
ML_FORECASTING_HORIZON=24
ML_CHANGE_POINT_THRESHOLD=0.8

# =============================================================================
# Notification Configuration
# =============================================================================
NOTIFICATION_EMAIL_ENABLED=false
NOTIFICATION_EMAIL_HOST=smtp.gmail.com
NOTIFICATION_EMAIL_PORT=587
NOTIFICATION_EMAIL_USERNAME=
NOTIFICATION_EMAIL_PASSWORD=
NOTIFICATION_EMAIL_FROM=noreply@sentinelai.io
NOTIFICATION_EMAIL_USE_TLS=true

NOTIFICATION_SLACK_ENABLED=false
NOTIFICATION_SLACK_WEBHOOK_URL=
NOTIFICATION_SLACK_CHANNEL=#incidents

NOTIFICATION_PAGERDUTY_ENABLED=false
NOTIFICATION_PAGERDUTY_API_KEY=
NOTIFICATION_PAGERDUTY_SERVICE_ID=

NOTIFICATION_DISCORD_ENABLED=false
NOTIFICATION_DISCORD_WEBHOOK_URL=

# =============================================================================
# Feature Flags
# =============================================================================
FEATURE_ANOMALY_DETECTION=true
FEATURE_AUTO_REMEDIATION=false
FEATURE_AI_SUGGESTIONS=true
FEATURE_ALERT_DEDUPLICATION=true
FEATURE_INCIDENT_TIMELINE=true
FEATURE_DEPLOYMENT_CORRELATION=true
FEATURE_LOG_INTELLIGENCE=true
FEATURE_TRACE_ANALYSIS=true
